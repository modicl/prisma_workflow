GOOGLE_GENAI_USE_VERTEXAI=0
GOOGLE_API_KEY=

# Langfuse — LLM observability (optional; leave blank to disable tracing)
# Get keys at https://cloud.langfuse.com → Settings → API Keys
# NOTE: ADK spans include LLM prompt content (student PACI data). Configure
# data retention and access controls in Langfuse before enabling in production.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

BD_LOGS=

# AWS S3 — Book Repository (política: PrismaSchoolsReposReadOnly)
AWS_ACCESS_KEY_ID=<nueva_access_key_tras_rotar>
AWS_SECRET_ACCESS_KEY=<nuevo_secret_tras_rotar>
AWS_REGION=us-east-1
S3_BUCKET_NAME=prisma-schools-repos

# Auth — Supabase JWKS (Project Settings > API > Project URL)
SUPABASE_URL=

# Event-driven architecture (dejar vacío para desarrollo local sin S3/Lambda)
S3_BUCKET=
DYNAMO_TABLE=
INTERNAL_TOKEN=