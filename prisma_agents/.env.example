# ─────────────────────────────────────────────────────────────────
#  PRISMA Workflow — Variables de entorno
#  Copia este archivo como .env y completa los valores reales.
#  NUNCA subas el .env al repositorio.
# ─────────────────────────────────────────────────────────────────

# ── Google AI ────────────────────────────────────────────────────
GOOGLE_GENAI_USE_VERTEXAI=0
GOOGLE_API_KEY=tu_api_key_de_google_ai_studio

# ── PostgreSQL (logs internos del ADK) ──────────────────────────
# Formato: postgresql+asyncpg://user:password@host/dbname?ssl=require
BD_LOGS=postgresql+asyncpg://usuario:password@host/dbname?ssl=require

# ── AWS ─────────────────────────────────────────────────────────
# Requerido solo si usas el repositorio de materiales S3 o DynamoDB
AWS_ACCESS_KEY_ID=tu_access_key_id
AWS_SECRET_ACCESS_KEY=tu_secret_access_key
AWS_REGION=us-east-2

# Bucket de materiales educativos por colegio (lectura)
S3_BUCKET_NAME=prisma-schools-repos

# ── Arquitectura event-driven (dejar vacío para desarrollo local) ─
# S3 bucket de jobs y resultados
S3_BUCKET=prisma-workflow
# Tabla DynamoDB de sesiones
DYNAMO_TABLE=prisma-sessions
# Secreto compartido entre el backend y la Lambda trigger
INTERNAL_TOKEN=cambia-esto-por-un-secreto-largo

# ── Supabase (autenticación JWT) ────────────────────────────────
SUPABASE_URL=https://<tu-proyecto>.supabase.co
SUPABASE_JWT_SECRET=tu_jwt_secret_de_supabase

# ── Langfuse (observabilidad LLM — opcional) ───────────────────
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com
